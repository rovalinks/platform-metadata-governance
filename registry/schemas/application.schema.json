{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Application Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "product",
    "team",
    "owner",
    "budgetOwner",
    "organization",
    "department",
    "costCenter",
    "bindings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "product": {
      "type": "string",
      "minLength": 1
    },
    "team": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "format": "email"
    },
    "budgetOwner": {
      "type": "string",
      "format": "email"
    },
    "organization": {
      "type": "string",
      "minLength": 1
    },
    "department": {
      "type": "string",
      "minLength": 1
    },
    "costCenter": {
      "type": "string",
      "minLength": 1
    },
    "bindings": {
      "type": "object",
      "required": [
        "gcp"
      ],
      "additionalProperties": false,
      "properties": {
        "gcp": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "projectId",
              "region",
              "environment",
              "businessCriticality"
            ],
            "properties": {
              "projectId": {
                "type": "string",
                "minLength": 1
              },
              "region": {
                "type": "string",
                "minLength": 1
              },
              "environment": {
                "type": "string",
                "minLength": 1
              },
              "businessCriticality": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}