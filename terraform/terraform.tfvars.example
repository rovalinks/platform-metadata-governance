# ------------------------------------------------------------------
# Google Cloud Project
# ------------------------------------------------------------------

project_id = "my-gcp-project"

region = "europe-west2"

# ------------------------------------------------------------------
# Artifact Registry
# ------------------------------------------------------------------

artifact_registry_repository = "platform-images"

artifact_registry_description = "Platform Metadata Governance Images"

# ------------------------------------------------------------------
# Service Accounts
# ------------------------------------------------------------------

service_accounts = {

  terraform = {
    account_id   = "terraform-sa"
    display_name = "Terraform Service Account"
    description  = "Deploys platform infrastructure using Terraform"
  }

  governance = {
    account_id   = "governance-engine-sa"
    display_name = "Metadata Governance Engine"
    description  = "Runs the Cloud Run governance service"
  }

  github = {
    account_id   = "github-actions-sa"
    display_name = "GitHub Actions"
    description  = "Used by GitHub Actions through Workload Identity Federation"
  }

  cloudbuild = {
    account_id   = "cloud-build-sa"
    display_name = "Cloud Build"
    description  = "Builds and deploys the governance platform"
  }
}

# ------------------------------------------------------------------
# IAM Roles
# ------------------------------------------------------------------

service_account_roles = {

  terraform = [
    "roles/serviceusage.serviceUsageAdmin",
    "roles/iam.serviceAccountAdmin",
    "roles/artifactregistry.admin"
  ]

  github = [
    "roles/cloudbuild.builds.editor",
    "roles/artifactregistry.writer",
    "roles/storage.objectAdmin",
    "roles/run.developer",
    "roles/serviceusage.serviceUsageConsumer"
  ]

  governance = [
    "roles/logging.logWriter",
    "roles/cloudasset.viewer",
    "roles/viewer"
  ]

  cloudbuild = [
    "roles/artifactregistry.writer",
    "roles/logging.logWriter",
    "roles/storage.objectViewer",
    "roles/run.developer"
  ]
}

# ------------------------------------------------------------------
# Cloud Run
# ------------------------------------------------------------------

cloud_run = {
  service_name = "metadata-governance"

  image = "europe-west2-docker.pkg.dev/my-gcp-project/platform-images/governance-engine:latest"
}

# ------------------------------------------------------------------
# Workload Identity Federation
# ------------------------------------------------------------------

workload_identity = {
  pool_id           = "github-pool"
  provider_id       = "github-provider"
  github_owner      = "my-github-org"
  github_repository = "my-repository"
}

# ------------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------------

deploy_cloud_run = true